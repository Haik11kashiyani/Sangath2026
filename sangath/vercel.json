{
  "version": 2,
  "builds": [
    {
      "src": "api/[[...slug]].js",
      "use": "@vercel/node"
    },
    {
      "src": "vite.config.js",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/[[...slug]].js" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
